{
  "name": "@ipguard/core",
  "version": "0.1.0",
  "description": "IP Guard - OPC 出海开发者的 IP 风险检测工具（CLI + Skills）",
  "license": "MIT",
  "type": "commonjs",
  "bin": {
    "ipguard": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('node:fs').cpSync('src/config','dist/config',{recursive:true})\"",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "install:local": "node install.js"
  },
  "dependencies": {
    "chalk": "5.3.0",
    "commander": "11.1.0",
    "fast-glob": "3.3.2",
    "opentype.js": "1.3.4",
    "spdx-license-list": "6.10.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.16.5",
    "@types/opentype.js": "1.3.8",
    "typescript": "5.6.3"
  },
  "packageManager": "pnpm@9.12.1"
}
